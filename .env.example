APP_NAME=Alzheimer Safety Dashboard
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=detection-images

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15555550100

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_API_URL=https://api.sendgrid.com/v3/mail/send
SENDGRID_FROM_EMAIL=alerts@example.com
SENDGRID_FROM_NAME=VALIANT
SENDGRID_REPLY_TO=

# Roboflow
ROBOFLOW_API_KEY=your-roboflow-api-key
ROBOFLOW_API_URL=https://detect.roboflow.com
ROBOFLOW_FIRE_MODEL_ID=fire-5vwyl/1
ROBOFLOW_GUN_MODEL_ID=gun-detection-s5poj/1
ROBOFLOW_EVERY_N_FRAMES=8

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# App config
PATIENT_ID=
CAMERA_INDEX=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30
CAMERA_BUFFER_SIZE=1
CAMERA_PREVIEW_FPS=10
FRAME_INTERVAL=0.75
FAMILIAR_THRESHOLD=5
FACE_MATCH_THRESHOLD=0.6
FACE_SCALE_FACTOR=0.5
FACE_DETECTION_UPSAMPLE=0
FACE_PROCESS_INTERVAL=0.75
ALERT_COOLDOWN_SECONDS=60
MEDICINE_COOLDOWN_SECONDS=3600
MEDICINE_SCAN_INTERVAL=1.5
MAX_MEDICINE_DETECTIONS_PER_FRAME=2
MEDICINE_CROP_PADDING=0.18
MEDICINE_CONFIDENCE_THRESHOLD=0.18
FACE_ALERT_COOLDOWN_SECONDS=300
YOLO_MODEL=yolov8n.pt
YOLO_IMAGE_SIZE=512
YOLO_MAX_DET=16
YOLO_HALF=false
YOLO_CONFIDENCE_THRESHOLD=0.35
PERSON_CONFIDENCE_THRESHOLD=0.35
HAZARD_CONFIDENCE_THRESHOLD=0.35
ROBOFLOW_HAZARD_CONFIDENCE_THRESHOLD=0.6

# Frontend runtime
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
